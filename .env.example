# ── Secrets ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TMDB_API_KEY=your_tmdb_api_key

# ── Access control ──────────────────────────────────────────────────
# Comma or space separated Telegram chat IDs where the bot is allowed.
ALLOWED_CHAT_IDS=-1001234567890
# Comma or space separated Telegram user IDs with admin privileges.
ADMIN_USER_IDS=123456789

# ── Permissions ─────────────────────────────────────────────────────
# UID and GID for the plexbot process and all downloaded files.
# Must match the user that owns your media directories on the host.
PUID=1000
PGID=1000

# File permission modes (octal, without leading zero in env).
PLEXBOT_DIR_MODE=0755
PLEXBOT_FILE_MODE=0644

# ── Runtime ────────────────────────────────────────────────────────
TZ=UTC
# PLEXBOT_LOG_PATH=bot.log
# TDL_HOME=/data/tdl